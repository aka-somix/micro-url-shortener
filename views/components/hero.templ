package components

templ HeroBanner() {
	<section class="flex flex-col items-center py-16 text-center">
		<h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
			Micro URL Shortener
		</h1>
		<p class="mt-4 max-w-md text-base text-gray-500">
			Shorten your links instantly. No signup, no tracking.
		</p>
	</section>
}