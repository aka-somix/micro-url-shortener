# ============================================================
# Go
# ============================================================

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of `go build`
/bin/
/dist/

# Go module cache (only if vendoring)
# vendor/

# Go workspace file
go.work.sum

# Coverage output
*.out
coverage.html

# Profiling output
*.prof
*.pprof

# ============================================================
# Air (live reload)
# ============================================================

# Air binary output (matches `tmp_dir` in .air.toml)
/tmp/

# Air config (optional — commit if you want shared config)
# .air.toml

# ============================================================
# Templ
# ============================================================

# Generated Go files from .templ sources
*_templ.go

# ============================================================
# Gin / Web server
# ============================================================

# Uploaded files (if stored locally)
/uploads/
/static/uploads/

